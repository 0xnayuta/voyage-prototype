generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

/// 存档表：Save + JSON 列模式
/// 整个 World 序列化为 JSON 存入 data 列
/// slot 0 = 自动存档（每次操作自动覆盖），1-3 = 手动存档位
model Save {
  id        String   @id @default(uuid())
  slot      Int      @unique // 0 = 自动存档, 1-3 = 手动存档
  data      String   // JSON: 整个 World 序列化
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
